---
import "../styles/global.css";

const researchAreas = [
  {
    id: "01",
    signal: "DELIBERATION",
    title: "Deep Thinking for LLMs",
    description:
      "Building language models that spend more time reasoning, test alternatives, and revise their judgment before they act.",
    question: "How can inference become a process of judgment?",
    tag: "Reasoning systems",
  },
  {
    id: "02",
    signal: "ADVERSARIAL COUNCIL",
    title: "AI Safety, by Debate",
    description:
      "Using councils of AI agents as both attackers and defenders to expose weak assumptions and improve system safety.",
    question: "Can disagreement become a safety mechanism?",
    tag: "AI alignment",
  },
  {
    id: "03",
    signal: "COLLECTIVE LIFE",
    title: "AI Computational Sociology",
    description:
      "Studying how synthetic agents form norms, coordinate, polarize, and reshape the institutions around them.",
    question: "What social orders emerge when agents can reason?",
    tag: "Social computing",
  },
  {
    id: "04",
    signal: "MORE-THAN-HUMAN",
    title: "Humans, Animals & Interfaces",
    description:
      "Designing interaction systems that treat animals as participants—not simply objects of sensing or automation.",
    question: "Who gets to be a user?",
    tag: "HCI",
  },
];

const projects = [
  {
    code: "AC / 01",
    title: "AI Council",
    state: "ACTIVE",
    description:
      "A multi-agent arena where models challenge one another, surface hidden failure modes, and turn adversarial pressure into safer decisions.",
    themes: ["Red teaming", "Deliberation", "Evaluation"],
  },
  {
    code: "DT / 02",
    title: "Deep Thinking · MCGS Law",
    state: "IN STUDY",
    description:
      "A deep-thinking framework that gives language models more time to decompose hard decisions, search game-theoretic alternatives, and revise premature answers.",
    themes: ["Deep reasoning", "Test-time compute", "Game-theoretic search"],
  },
  {
    code: "CG / 03",
    title: "ContractGalaxy",
    state: "DEMO",
    description:
      "An interactive contract-intelligence system that maps clauses, obligations, and risks into an explorable galaxy of relationships.",
    themes: ["Contract intelligence", "Knowledge graphs", "Interactive reasoning"],
    video: "contract-galaxy-demo.mp4",
  },
  {
    code: "HI / 04",
    title: "More-than-human Interfaces",
    state: "EXPLORATORY",
    description:
      "Interaction concepts at the human–animal–AI boundary, asking how technology can support mutual attention rather than one-way control.",
    themes: ["Animal–computer interaction", "Embodied AI", "Care"],
  },
];

const experience = [
  {
    years: "2026—NOW",
    organization: "HKUST",
    role: "PhD Researcher · Artificial Intelligence",
    note: "Deep thinking, game theory, HCI, and computational social science.",
  },
  {
    years: "2025—NOW",
    organization: "Hong Kong Generative AI R&D Center",
    role: "Full-stack Engineer",
    note: "AIGC applications, LLM integration, and contributions to Open WebUI.",
  },
  {
    years: "2021—2024",
    organization: "Alibaba Group",
    role: "Senior Front-end Engineer",
    note: "Large-scale public service systems, performance engineering, and two patents.",
  },
  {
    years: "2019—2021",
    organization: "Kuaishou · Huawei",
    role: "Software Engineer",
    note: "Creative tooling, automated testing, and the early HarmonyOS ecosystem.",
  },
];

const currentYear = new Date().getFullYear();
const assetBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const avatarImage = `${assetBase}avatar.jpg`;
const contractGalaxyVideo = `${assetBase}contract-galaxy-demo.mp4`;
const socialImage = new URL(`${assetBase}og.png`, Astro.url);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Chen Long is an AI PhD researcher at HKUST working on LLM deep thinking, AI safety, computational sociology, and more-than-human interaction."
    />
    <meta name="theme-color" content="#f2efe6" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Chen Long — AI Researcher" />
    <meta
      property="og:description"
      content="Researching how intelligent systems reason, disagree, organize, and coexist."
    />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={socialImage} />
    <title>Chen Long — AI Researcher at HKUST</title>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="progress" aria-hidden="true"><span data-progress></span></div>

    <header class="site-header" data-header>
      <a class="wordmark" href="#top" aria-label="Chen Long, home">
        <span class="wordmark-avatar" aria-hidden="true">
          <img src={avatarImage} alt="" width="42" height="42" />
        </span>
        <span class="wordmark-copy">CHEN LONG<br />陈 龙</span>
      </a>
      <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="main-nav">
        <span>Menu</span>
        <i aria-hidden="true"></i>
      </button>
      <nav id="main-nav" aria-label="Primary navigation">
        <a href="#research">Research</a>
        <a href="#projects">Projects</a>
        <a href="#trajectory">Trajectory</a>
        <a class="nav-contact" href="mailto:lchenew@connect.ust.hk">Let’s talk ↗</a>
      </nav>
    </header>

    <main id="main">
      <section class="hero" id="top">
        <div class="hero-index" aria-hidden="true">
          <span>HK / 22.3379° N</span>
          <span>FIELD NOTES · 2026</span>
        </div>

        <div class="hero-copy">
          <p class="eyebrow reveal">AI PHD RESEARCHER · HKUST</p>
          <h1 class="reveal">
            Thinking<br />
            <em>before</em> acting.
          </h1>
          <p class="hero-intro reveal">
            I’m <strong>Chen Long</strong>. I study how intelligent systems reason,
            disagree, organize, and coexist—with humans, with other AIs, and with
            other living beings.
          </p>
          <div class="hero-links reveal">
            <a class="primary-link" href="#research">Explore the research <span>↓</span></a>
            <a href="https://github.com/chenqianwan" target="_blank" rel="noreferrer">GitHub ↗</a>
            <a href="mailto:lchenew@connect.ust.hk">Email ↗</a>
          </div>
        </div>

        <div class="thinking-map reveal" aria-label="Four connected research themes">
          <div class="map-orbit orbit-one"></div>
          <div class="map-orbit orbit-two"></div>
          <span class="map-axis axis-x"></span>
          <span class="map-axis axis-y"></span>
          <div class="map-center"><span>WHY</span><b>?</b></div>
          <div class="map-node node-a"><i></i><span>Reason</span></div>
          <div class="map-node node-b"><i></i><span>Disagree</span></div>
          <div class="map-node node-c"><i></i><span>Organize</span></div>
          <div class="map-node node-d"><i></i><span>Coexist</span></div>
          <p>ONE QUESTION,<br />FOUR SCALES</p>
        </div>

        <div class="scroll-note" aria-hidden="true"><span></span>SCROLL TO TRACE THE WORK</div>
      </section>

      <section class="statement section-pad reveal">
        <p class="section-kicker">RESEARCH POSITION / 00</p>
        <div class="statement-grid">
          <h2>Intelligence is not just an answer.</h2>
          <p>
            It is the process that precedes an answer: hesitation, debate,
            coordination, and care. My work treats AI as both a technical system
            and a new participant in social life.
          </p>
        </div>
      </section>

      <section class="research section-pad" id="research">
        <div class="section-heading reveal">
          <div>
            <p class="section-kicker">RESEARCH AGENDA / 01—04</p>
            <h2>Four lines of inquiry</h2>
          </div>
          <p class="section-aside">Connected by a concern for better judgment.</p>
        </div>

        <div class="research-list">
          {researchAreas.map((area) => (
            <article class="research-row reveal">
              <div class="row-number">{area.id}</div>
              <div class="row-signal">{area.signal}</div>
              <div class="row-body">
                <h3>{area.title}</h3>
                <p>{area.description}</p>
                <blockquote>“{area.question}”</blockquote>
              </div>
              <div class="row-tag"><span>{area.tag}</span><i aria-hidden="true">↗</i></div>
            </article>
          ))}
        </div>
      </section>

      <section class="projects section-pad" id="projects">
        <div class="projects-intro reveal">
          <p class="section-kicker light">CURRENT PROJECTS / OPEN NOTEBOOK</p>
          <h2>Ideas become useful when they survive contact.</h2>
          <p>
            These projects are working instruments—part experiment, part critique,
            part prototype. They are intentionally unfinished.
          </p>
        </div>

        <div class="project-grid">
          {projects.map((project, index) => (
            <article
              class:list={["project-card", "reveal", { "project-card--video": project.video }]}
              style={`--delay: ${index * 70}ms`}
              tabindex={project.video ? "0" : undefined}
              data-video-card={project.video ? "" : undefined}
              aria-label={project.video ? `${project.title}. Hover, focus, or tap to play the demo.` : undefined}
            >
              {project.video && (
                <video
                  class="project-video"
                  src={contractGalaxyVideo}
                  muted
                  loop
                  playsinline
                  preload="metadata"
                  aria-hidden="true"
                ></video>
              )}
              <div class="project-meta">
                <span>{project.code}</span>
                <span class="project-state"><i></i>{project.state}</span>
              </div>
              <h3>{project.title}</h3>
              <p>{project.description}</p>
              <ul aria-label={`${project.title} themes`}>
                {project.themes.map((theme) => <li>{theme}</li>)}
              </ul>
              {project.video && (
                <>
                  <span class="project-play-hint" aria-hidden="true">HOVER / FOCUS / TAP TO PLAY ↗</span>
                  <span class="video-now-playing" aria-hidden="true">CONTRACTGALAXY · PLAYING</span>
                </>
              )}
            </article>
          ))}
        </div>
      </section>

      <section class="trajectory section-pad" id="trajectory">
        <div class="section-heading reveal">
          <div>
            <p class="section-kicker">TRAJECTORY / 2015—NOW</p>
            <h2>From systems at scale<br />to questions at depth.</h2>
          </div>
          <p class="section-aside">
            Engineering taught me how systems behave in the world.<br />Research asks what they should become.
          </p>
        </div>

        <div class="timeline">
          {experience.map((item) => (
            <article class="timeline-row reveal">
              <time>{item.years}</time>
              <h3>{item.organization}</h3>
              <div>
                <p class="timeline-role">{item.role}</p>
                <p>{item.note}</p>
              </div>
            </article>
          ))}
        </div>

        <div class="education-note reveal">
          <span>FOUNDATION / 2015—2019</span>
          <p>B.Eng. in Software Engineering</p>
          <p>Shandong University · Jinan, China</p>
        </div>
      </section>

      <section class="contact section-pad">
        <div class="contact-mark" aria-hidden="true">↘</div>
        <p class="section-kicker light reveal">CONTACT / OPEN CHANNEL</p>
        <h2 class="reveal">Let’s build systems<br />worth thinking with.</h2>
        <p class="contact-note reveal">
          I’m interested in research collaborations, unusual HCI questions, and
          conversations across technical and social boundaries.
        </p>
        <a class="contact-email reveal" href="mailto:lchenew@connect.ust.hk">
          <span>lchenew@connect.ust.hk</span><i>↗</i>
        </a>
      </section>
    </main>

    <footer>
      <p>CHEN LONG · AI RESEARCHER</p>
      <p>HONG KONG · {currentYear}</p>
      <div>
        <a href="https://github.com/chenqianwan" target="_blank" rel="noreferrer">GITHUB ↗</a>
        <a href="#top">BACK TO TOP ↑</a>
      </div>
    </footer>

    <script>
      const toggle = document.querySelector<HTMLButtonElement>(".menu-toggle");
      const nav = document.querySelector<HTMLElement>("#main-nav");
      const progress = document.querySelector<HTMLElement>("[data-progress]");
      const header = document.querySelector<HTMLElement>("[data-header]");

      toggle?.addEventListener("click", () => {
        const expanded = toggle.getAttribute("aria-expanded") === "true";
        toggle.setAttribute("aria-expanded", String(!expanded));
        nav?.classList.toggle("is-open", !expanded);
      });

      nav?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          toggle?.setAttribute("aria-expanded", "false");
          nav.classList.remove("is-open");
        });
      });

      const updateScroll = () => {
        const max = document.documentElement.scrollHeight - window.innerHeight;
        const ratio = max > 0 ? window.scrollY / max : 0;
        if (progress) progress.style.transform = `scaleX(${ratio})`;
        header?.classList.toggle("is-scrolled", window.scrollY > 24);
      };

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.14 },
      );

      document.querySelectorAll(".reveal").forEach((element) => observer.observe(element));

      document.querySelectorAll<HTMLElement>("[data-video-card]").forEach((card) => {
        const video = card.querySelector<HTMLVideoElement>(".project-video");
        if (!video) return;

        const activate = () => {
          card.classList.add("is-video-active");
          void video.play().catch(() => {
            card.classList.remove("is-video-active");
          });
        };

        const deactivate = () => {
          card.classList.remove("is-video-active");
          video.pause();
          video.currentTime = 0;
        };

        card.addEventListener("mouseenter", activate);
        card.addEventListener("mouseleave", deactivate);
        card.addEventListener("focus", () => {
          if (card.matches(":focus-visible")) activate();
        });
        card.addEventListener("blur", deactivate);
        card.addEventListener("click", () => {
          if (!window.matchMedia("(hover: none)").matches) return;
          if (card.classList.contains("is-video-active")) deactivate();
          else activate();
        });
        card.addEventListener("keydown", (event) => {
          if (event.key !== "Enter" && event.key !== " ") return;
          event.preventDefault();
          if (card.classList.contains("is-video-active")) deactivate();
          else activate();
        });
      });

      window.addEventListener("scroll", updateScroll, { passive: true });
      updateScroll();
    </script>
  </body>
</html>
